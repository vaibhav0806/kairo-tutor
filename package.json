{
  "name": "kairo-tutor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "server"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "app": "bash scripts/rebuild-run.sh",
    "dist": "bash scripts/build-dmg.sh",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:providers": "node scripts/smoke-providers.mjs",
    "server:dev": "npm run dev -w @kairo/server",
    "server:build": "npm run build -w @kairo/server",
    "server:start": "npm run start -w @kairo/server",
    "server:test": "npm run test -w @kairo/server",
    "db:generate": "npm run db:generate -w @kairo/server",
    "db:migrate": "npm run db:migrate -w @kairo/server"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource/instrument-serif": "^5.3.0",
    "@tauri-apps/api": "^2.11.1",
    "@uiw/react-color-shade-slider": "^2.10.3",
    "@uiw/react-color-wheel": "^2.10.3",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
