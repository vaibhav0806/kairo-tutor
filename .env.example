KAIRO_APP_ENV=development
KAIRO_AI_PROVIDER=openrouter
KAIRO_STT_PROVIDER=sarvam
KAIRO_TTS_PROVIDER=sarvam
KAIRO_DEFAULT_SKILL=blender
KAIRO_ENABLE_WEB_RESEARCH=false

# Required only when KAIRO_AI_PROVIDER=openrouter.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=~openai/gpt-latest
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_TITLE=Kairo Tutor

# Required only when KAIRO_STT_PROVIDER=sarvam or KAIRO_TTS_PROVIDER=sarvam.
SARVAM_API_KEY=
SARVAM_BASE_URL=https://api.sarvam.ai
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=transcribe
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_LANGUAGE_CODE=en-IN
SARVAM_TTS_SPEAKER=shubh

# Required only when KAIRO_STT_PROVIDER=elevenlabs or KAIRO_TTS_PROVIDER=elevenlabs.
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_STT_MODEL=scribe_v1
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
