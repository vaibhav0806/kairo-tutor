# Kairo server env — KEYS ONLY (this file is committed with placeholder names, never values).
# Copy to server/.env and fill. server/.env is gitignored.
PORT=8787
PUBLIC_BASE_URL=http://localhost:8787

# Neon Postgres — use the POOLED connection string (host contains "-pooler").
DATABASE_URL=

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Google OAuth (redirect URI: http://localhost:8787/api/auth/callback/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI provider keys (proxied server-side; never reach the desktop bundle)
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
SARVAM_API_KEY=
ELEVENLABS_API_KEY=

# Dodo Payments — TEST MODE ONLY in dev; live keys only on Hetzner prod.
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_SECRET=
DODO_ENV=test_mode
